# MindSet Capital - .gitignore

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*

# Temporary files
*.tmp
temp/
tmp/

# Local environment
.env
.env.local

# Cache
.cache/
*.cache

# Node modules (si decides usar npm en el futuro)
node_modules/

# Build outputs (si decides usar un build tool)
dist/
build/

# Artefactos de pruebas E2E
test-results/
playwright-report/
playwright-report.json
e2e-output.txt

# Backups
*.bak
*.backup
backup/

# User data exports (si implementas export/import)
exports/
data/
backups/
